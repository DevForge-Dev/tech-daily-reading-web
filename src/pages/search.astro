---
import Base from '../layouts/Base.astro';
import { url } from '../lib/url';
---

<Base title="検索" description="読み物を全文検索（クライアントサイド）" current="search">
  <h1 class="page-title">検索</h1>
  <p class="page-sub">タイトル・本文・出典を横断して検索します（すべてブラウザ内で処理）。</p>

  <div class="search-box">
    <span class="search-icon" aria-hidden="true">🔍</span>
    <input
      type="search"
      id="q"
      placeholder="キーワードを入力（例: Riverpod、@starting-style、サブエージェント）"
      autocomplete="off"
      autofocus
    />
  </div>

  <p class="muted" id="status">読み込み中…</p>
  <div id="results"></div>
</Base>

<script is:inline define:vars={{ indexUrl: url('search-index.json'), base: url('') }}>
  (function () {
    const q = document.getElementById('q');
    const results = document.getElementById('results');
    const status = document.getElementById('status');
    let data = [];

    function articleUrl(id) {
      return (base + '/articles/' + id + '/').replace(/\/{2,}/g, '/');
    }
    function esc(s) {
      return s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    }
    function highlight(text, terms) {
      let out = esc(text);
      terms.forEach((t) => {
        if (!t) return;
        const re = new RegExp('(' + t.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
        out = out.replace(re, '<mark>$1</mark>');
      });
      return out;
    }
    function snippet(text, terms) {
      const lower = text.toLowerCase();
      let pos = -1;
      for (const t of terms) {
        const i = lower.indexOf(t.toLowerCase());
        if (i !== -1 && (pos === -1 || i < pos)) pos = i;
      }
      if (pos === -1) return text.slice(0, 140) + '…';
      const start = Math.max(0, pos - 50);
      return (start > 0 ? '…' : '') + text.slice(start, start + 160) + '…';
    }

    function render(query) {
      const terms = query.trim().toLowerCase().split(/\s+/).filter(Boolean);
      if (!terms.length) {
        results.innerHTML = '';
        status.textContent = 'キーワードを入力してください。全 ' + data.length + ' 本が対象です。';
        return;
      }
      const scored = [];
      for (const a of data) {
        const hayTitle = (a.title + ' ' + a.lede + ' ' + a.topic).toLowerCase();
        const hayText = a.text.toLowerCase();
        let score = 0;
        let ok = true;
        for (const t of terms) {
          const inTitle = hayTitle.includes(t);
          const inText = hayText.includes(t);
          if (!inTitle && !inText) {
            ok = false;
            break;
          }
          score += (inTitle ? 5 : 0) + (inText ? 1 : 0);
        }
        if (ok) scored.push({ a, score });
      }
      scored.sort((x, y) => y.score - x.score);
      if (!scored.length) {
        results.innerHTML = '';
        status.textContent = '「' + query + '」に一致する読み物はありませんでした。';
        return;
      }
      status.textContent = scored.length + ' 件ヒット';
      results.innerHTML = scored
        .map(({ a }) => {
          const grad = 'linear-gradient(135deg,' + a.color + ',' + a.color + ')';
          return (
            '<a class="search-result-item" href="' +
            articleUrl(a.id) +
            '">' +
            '<span class="chip" style="background:' +
            a.color +
            '">' +
            a.glyph +
            ' ' +
            esc(a.topic) +
            '</span>' +
            '<h3>' +
            highlight(a.title, terms) +
            '</h3>' +
            '<p>' +
            highlight(snippet(a.text, terms), terms) +
            '</p>' +
            '</a>'
          );
        })
        .join('');
    }

    fetch(indexUrl)
      .then((r) => r.json())
      .then((json) => {
        data = json;
        const params = new URLSearchParams(location.search);
        const initial = params.get('q') || '';
        if (initial) q.value = initial;
        render(q.value);
        q.addEventListener('input', function () {
          render(q.value);
          const u = new URL(location.href);
          if (q.value) u.searchParams.set('q', q.value);
          else u.searchParams.delete('q');
          history.replaceState(null, '', u);
        });
      })
      .catch(function () {
        status.textContent = '検索インデックスの読み込みに失敗しました。';
      });
  })();
</script>
