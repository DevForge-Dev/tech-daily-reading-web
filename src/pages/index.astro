---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getArticles, groupByTopic, topicMeta, getGeneratedAt } from '../lib/data';
import { url } from '../lib/url';

const articles = getArticles();
const featured = articles[0];
const rest = articles.slice(1);
const byTopic = groupByTopic(articles);
const generatedAt = getGeneratedAt();
const updated = generatedAt
  ? new Date(generatedAt).toLocaleString('ja-JP', { dateStyle: 'medium', timeStyle: 'short' })
  : '';
---

<Base title="デイリー技術深掘り 読み物" current="home" themeColor={topicMeta(featured?.topic ?? '').color}>
  {
    featured && (
      <a class="hero-link" href={url(`articles/${featured.id}/`)} style="display:block; margin-top:24px;">
        <Hero article={featured} />
      </a>
    )
  }

  {
    updated && (
      <p class="muted" style="margin:14px 2px 0; font-size:13px;">
        最終更新: {updated} ／ 全 {articles.length} 本
      </p>
    )
  }

  <div class="section-head">
    <h2>最新の読み物</h2>
    <a class="more" href={url('archive')}>アーカイブを見る →</a>
  </div>

  {
    rest.length > 0 ? (
      <div class="card-grid">
        {rest.map((a) => (
          <ArticleCard article={a} />
        ))}
      </div>
    ) : (
      <p class="empty">まだ記事がありません。</p>
    )
  }

  <div class="section-head">
    <h2>トピック</h2>
    <a class="more" href={url('trends')}>傾向グラフ →</a>
  </div>

  <div class="card-grid" style="grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));">
    {
      byTopic.map((g) => {
        const grad = `linear-gradient(135deg, ${g.meta.gradient[0]}, ${g.meta.gradient[1]})`;
        return (
          <a class="topic-tile" href={url(`topics/${g.meta.slug}/`)} style={`background:${grad}`}>
            <span class="glyph" aria-hidden="true">{g.meta.glyph}</span>
            <div class="topic-name">{g.meta.name}</div>
            <div class="count">
              {g.articles.length}
              <span> 本</span>
            </div>
          </a>
        );
      })
    }
  </div>
</Base>
